{
  "datasets": [
    {
      "name": "gold_custos",
      "displayName": "Custos de Manutenção",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  workshop_databricks.gabriel_rangel.gold_custos_manutencao"
      ],
      "columns": [
        {
          "displayName": "Variância Custo (%)",
          "description": "Percentage difference between real and estimated cost",
          "expression": "(SUM(`custo_real_total`) - SUM(`custo_estimado_total`)) / SUM(`custo_estimado_total`) * 100"
        }
      ]
    },
    {
      "name": "gold_producao",
      "displayName": "Produção por Campo",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  workshop_databricks.gabriel_rangel.gold_producao_por_campo"
      ]
    },
    {
      "name": "pocos_mapa",
      "displayName": "Mapa de Poços",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  workshop_databricks.gabriel_rangel.bronze_pocos\n",
        "WHERE\n",
        "  latitude IS NOT NULL\n",
        "  AND longitude IS NOT NULL"
      ]
    },
    {
      "name": "gold_eficiencia",
      "displayName": "Eficiência Operacional",
      "queryLines": [
        "SELECT\n",
        "  e.*,\n",
        "  p.bacia\n",
        "FROM\n",
        "  workshop_databricks.gabriel_rangel.gold_eficiencia_operacional e\n",
        "    JOIN workshop_databricks.gabriel_rangel.gold_producao_por_campo p\n",
        "      ON e.campo = p.campo"
      ]
    }
  ],
