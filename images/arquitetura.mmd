  "theme": "dark",
  "themeVariables": {
    "primaryColor": "#1E3A5F",
    "primaryTextColor": "#E8F4FD",
    "primaryBorderColor": "#2E86AB",
    "lineColor": "#FF6B35",
    "secondaryColor": "#0D2137",
    "tertiaryColor": "#152535",
    "background": "#0A1929",
    "mainBkg": "#0D2137",
    "nodeBorder": "#2E86AB",
    "clusterBkg": "#0D2137",
